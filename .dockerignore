# ============================================================
# Docker构建忽略文件
# 排除不需要进入Docker构建上下文的文件和目录，加快构建速度
# ============================================================

# ==================== Git相关 ====================
.git
.gitignore
.gitattributes

# ==================== IDE相关 ====================
.idea
*.iml
.vscode
.project
.classpath
.settings
*.swp
*.swo
*~

# ==================== 构建输出目录 ====================
target/
build/
dist/
out/

# ==================== 前端依赖和构建产物（构建阶段会重新安装和构建） ====================
frontend/node_modules/
frontend/dist/

# ==================== 日志文件 ====================
*.log
logs/

# ==================== 临时文件 ====================
*.tmp
*.temp
*.bak
*.cache

# ==================== 操作系统文件 ====================
.DS_Store
Thumbs.db
Desktop.ini

# ==================== 文档和说明 ====================
README.md
docs/
*.md
LICENSE

# ==================== Maven相关（本地仓库） ====================
.mvn/
mvnw
mvnw.cmd

# ==================== Docker相关 ====================
docker-compose*.yml
Dockerfile
.dockerignore

# ==================== 其他 ====================
.superpowers/
.env
.env.*
*.env
