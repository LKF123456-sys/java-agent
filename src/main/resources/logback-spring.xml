<?xml version="1.0" encoding="UTF-8"?>
<!--
    Logback Spring Boot配置文件
    功能说明：
    - 控制台输出：开发环境彩色日志，包含traceId、spanId
    - 普通文件输出：按天滚动，保留30天，单文件最大100MB，总大小上限10GB
    - JSON文件输出：使用LogstashEncoder，供ELK采集，包含traceId/spanId/userId/requestPath等MDC字段
    - 错误日志单独输出
    - 多环境Profile支持：dev（控制台+文件）、docker（控制台+JSON文件）
-->
<configuration scan="true" scanPeriod="30 seconds">

    <!-- 定义日志文件存储路径 -->
    <property name="LOG_PATH" value="${LOG_PATH:-./logs}"/>
    <!-- 定义应用名称 -->
    <property name="APP_NAME" value="${SPRING_APPLICATION_NAME:-cyber-ai-platform}"/>
    <!-- 定义控制台彩色日志格式Pattern（含traceId、spanId） -->
    <property name="CONSOLE_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [%X{traceId:-}] [%X{spanId:-}] %-5level %logger{50} - %msg%n"/>
    <!-- 定义普通文件日志格式Pattern（含traceId、spanId） -->
    <property name="FILE_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [%X{traceId:-}] [%X{spanId:-}] %-5level %logger{50} - %msg%n"/>

    <!-- ==================== 控制台输出Appender ==================== -->
    <!-- 开发环境使用彩色Pattern格式输出到控制台 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <!-- 启用彩色输出 -->
        <withJansi>true</withJansi>
        <encoder>
            <!-- 使用包含traceId、spanId的彩色Pattern格式 -->
            <pattern>${CONSOLE_PATTERN}</pattern>
            <!-- 设置字符编码为UTF-8 -->
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ==================== 普通文件输出Appender ==================== -->
    <!-- 按天滚动生成日志文件，保留30天，单文件最大100MB，总大小上限10GB -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <!-- 当前活动日志文件路径 -->
        <file>${LOG_PATH}/app.log</file>
        <!-- 滚动策略：基于时间和大小的滚动策略 -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- 滚动后的日志文件名格式：按天命名 -->
            <fileNamePattern>${LOG_PATH}/app.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <!-- 单个日志文件最大大小：100MB -->
            <maxFileSize>100MB</maxFileSize>
            <!-- 日志文件总大小上限：10GB -->
            <totalSizeCap>10GB</totalSizeCap>
            <!-- 日志文件保留天数：30天 -->
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <!-- 使用包含traceId、spanId的Pattern格式 -->
            <pattern>${FILE_PATTERN}</pattern>
            <!-- 设置字符编码为UTF-8 -->
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ==================== JSON日志输出Appender ==================== -->
    <!-- 使用LogstashEncoder输出JSON格式日志，供ELK/Loki等日志系统采集 -->
    <!-- 文件命名模式：app-json-*.log，匹配Logstash采集路径配置 -->
    <appender name="JSON_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <!-- 当前活动JSON日志文件路径（使用连字符命名，匹配app-json-*.log模式） -->
        <file>${LOG_PATH}/app-json-current.log</file>
        <!-- 滚动策略：基于时间和大小的滚动策略 -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- 滚动后的JSON日志文件名格式：按天命名，使用连字符分隔（app-json-yyyy-MM-dd.i.log） -->
            <fileNamePattern>${LOG_PATH}/app-json-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <!-- 单个JSON日志文件最大大小：100MB -->
            <maxFileSize>100MB</maxFileSize>
            <!-- JSON日志文件总大小上限：10GB -->
            <totalSizeCap>10GB</totalSizeCap>
            <!-- JSON日志文件保留天数：30天 -->
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <!-- 使用LogstashEncoder输出JSON格式 -->
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <!-- 设置字符编码为UTF-8 -->
            <charset>UTF-8</charset>
            <!-- 配置包含的MDC字段（映射诊断上下文），这些字段会被包含在JSON输出中 -->
            <includeMdcKeyName>traceId</includeMdcKeyName>
            <includeMdcKeyName>spanId</includeMdcKeyName>
            <includeMdcKeyName>userId</includeMdcKeyName>
            <includeMdcKeyName>requestPath</includeMdcKeyName>
            <includeMdcKeyName>requestMethod</includeMdcKeyName>
            <!-- 添加自定义字段：应用名称 -->
            <customFields>{"appName":"${APP_NAME}"}</customFields>
            <!-- 包含时间戳 -->
            <includeTimestamp>true</includeTimestamp>
            <!-- 包含日志级别 -->
            <includeLevel>true</includeLevel>
            <!-- 包含线程名 -->
            <includeThreadName>true</includeThreadName>
            <!-- 包含Logger名称 -->
            <includeLoggerName>true</includeLoggerName>
            <!-- 包含调用位置信息（类名、方法名、行号） -->
            <includeCallerData>false</includeCallerData>
            <!-- 包含MDC上下文 -->
            <includeMdc>true</includeMdc>
            <!-- 时间戳格式 -->
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSSZZ</timestampPattern>
        </encoder>
    </appender>

    <!-- ==================== 错误日志单独输出Appender ==================== -->
    <!-- 仅输出ERROR级别及以上的日志，单独存储在error日志文件中 -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <!-- 当前活动错误日志文件路径 -->
        <file>${LOG_PATH}/error.log</file>
        <!-- 过滤器：仅接受ERROR级别日志 -->
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <!-- 设置过滤级别为ERROR，只有ERROR及以上级别日志才会被记录 -->
            <level>ERROR</level>
        </filter>
        <!-- 滚动策略：基于时间和大小的滚动策略 -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- 滚动后的错误日志文件名格式：按天命名 -->
            <fileNamePattern>${LOG_PATH}/error.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <!-- 单个错误日志文件最大大小：100MB -->
            <maxFileSize>100MB</maxFileSize>
            <!-- 错误日志文件总大小上限：10GB -->
            <totalSizeCap>10GB</totalSizeCap>
            <!-- 错误日志文件保留天数：30天 -->
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <!-- 使用包含traceId、spanId的Pattern格式 -->
            <pattern>${FILE_PATTERN}</pattern>
            <!-- 设置字符编码为UTF-8 -->
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ==================== 开发环境（dev）Profile配置 ==================== -->
    <!-- 默认激活dev Profile，输出到控制台和普通文件 -->
    <springProfile name="dev | default">
        <!-- 设置根日志级别为INFO（可通过logging.level.*配置覆盖） -->
        <root level="INFO">
            <!-- 控制台输出 -->
            <appender-ref ref="CONSOLE"/>
            <!-- 普通文件输出 -->
            <appender-ref ref="FILE"/>
            <!-- 错误日志单独输出 -->
            <appender-ref ref="ERROR_FILE"/>
        </root>
    </springProfile>

    <!-- ==================== Docker环境Profile配置 ==================== -->
    <!-- Docker容器环境，输出到控制台和JSON文件（供ELK采集） -->
    <springProfile name="docker">
        <!-- 设置根日志级别为INFO -->
        <root level="INFO">
            <!-- 控制台输出 -->
            <appender-ref ref="CONSOLE"/>
            <!-- JSON文件输出（供ELK/Loki采集） -->
            <appender-ref ref="JSON_FILE"/>
            <!-- 错误日志单独输出 -->
            <appender-ref ref="ERROR_FILE"/>
        </root>
    </springProfile>

</configuration>